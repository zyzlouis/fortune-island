<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>财神殿 — The Palace of Wealth</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🏮</text></svg>" />
  <link rel="stylesheet" href="css/style.css?v=2" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;700;900&family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- ===== 顶部导航 ===== -->
  <nav class="navbar" id="navbar">
    <div class="nav-inner">
      <a href="#" class="logo">
        <span class="logo-icon">🏮</span>
        <span class="logo-text" data-i18n="nav.logo">财神殿</span>
      </a>
      <ul class="nav-links" id="navLinks">
        <li><a href="#oracle" data-i18n="nav.oracle">神谕</a></li>
        <li><a href="#ritual" data-i18n="nav.ritual">法事服务</a></li>
        <li><a href="#bazi" data-i18n="nav.bazi">八字命理</a></li>
        <li><a href="#welfare" data-i18n="nav.welfare">🎁 福利中心</a></li>
        <li><a href="#staking" data-i18n="nav.staking">敬献香火</a></li>
        <li><a href="#gamefi" data-i18n="nav.gamefi">神兽试炼</a></li>
        <li><a href="#nft" data-i18n="nav.nft">财神宝库</a></li>
        <li><a href="#tokenomics" data-i18n="nav.token">$MONEYGOD</a></li>
        <li><a href="#market" data-i18n="nav.market">行情</a></li>
      </ul>
      <div class="nav-actions">
        <button class="lang-toggle" id="langToggle" title="切换语言 / Switch Language">
          <span class="lang-zh active">中</span>
          <span class="lang-sep">/</span>
          <span class="lang-en">EN</span>
        </button>
        <button class="btn btn-gold" id="connectWallet">
          <span class="btn-icon">⛓️</span> <span data-i18n="nav.connect">连接钱包</span>
        </button>
        <button class="mobile-menu-btn" id="mobileMenuBtn">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </nav>

  <!-- ===== 英雄区 ===== -->
  <section class="hero" id="hero">
    <div class="hero-particles" id="heroParticles"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="hero-badge" data-i18n="hero.badge">⚡ 基于区块链的财神文化平台</div>
      <h1 class="hero-title">
        <span class="title-line" data-i18n="hero.title1">赵公明</span>
        <span class="title-line gold" data-i18n="hero.title2">财神殿</span>
      </h1>
      <p class="hero-subtitle" data-i18n="hero.subtitle">
        以正财神赵公明为核心 IP，融合 DeFi · GameFi · NFT<br />
        将千年财神文化与 Web3 技术完美结合
      </p>
      <div class="hero-stats">
        <div class="stat-item">
          <span class="stat-value" id="tvlValue">$12,888,888</span>
          <span class="stat-label" data-i18n="hero.tvl">总锁仓量 (TVL)</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-value" id="usersValue">28,888</span>
          <span class="stat-label" data-i18n="hero.users">香客数量</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-value" id="nftValue">8,888</span>
          <span class="stat-label" data-i18n="hero.nfts">法器 NFT</span>
        </div>
      </div>
      <div class="hero-actions">
        <a href="#staking" class="btn btn-primary btn-lg" data-i18n="hero.cta1">
          🔥 敬献香火
        </a>
        <a href="#nft" class="btn btn-outline btn-lg" data-i18n="hero.cta2">
          ⚔️ 探索宝库
        </a>
      </div>
    </div>
    <!-- 财神形象 -->
    <div class="hero-figure">
      <div class="god-aura"></div>
      <div class="god-figure">
        <div class="god-halo"></div>
        <div class="god-body">
          <div class="god-face">
            <div class="god-hat">👑</div>
            <div class="god-head">🧔</div>
          </div>
          <div class="god-robe">
            <span class="robe-symbol">財</span>
          </div>
          <div class="god-weapon-left">🔱</div>
          <div class="god-weapon-right">💰</div>
        </div>
        <div class="god-tiger">🐅</div>
      </div>
    </div>
    <div class="scroll-indicator">
      <span data-i18n="hero.scroll">向下探索</span>
      <div class="scroll-arrow"></div>
    </div>
  </section>

  <!-- ===== 财神神谕 ===== -->
  <section class="section oracle-section" id="oracle">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Daily Oracle</span>
        <h2 class="section-title" data-i18n="oracle.title">📜 财神神谕</h2>
        <p class="section-desc" data-i18n="oracle.desc">赵公明每日为您开示财运玄机，指引投资方向</p>
      </div>
      <div class="oracle-card">
        <div class="oracle-decoration-left">福</div>
        <div class="oracle-decoration-right">禄</div>
        <div class="oracle-inner">
          <div class="oracle-seal" data-i18n="oracle.seal">赵公明印</div>
          <div class="oracle-date" id="oracleDate"></div>
          <div class="oracle-divider-top"></div>
          <p class="oracle-text" id="oracleText">
            今日宜守不宜攻，大盘震荡筑底中。<br />
            逢低布局蓝筹链，静待黑虎啸山风。
          </p>
          <div class="oracle-divider-bottom"></div>
          <div class="oracle-fortune">
            <div class="fortune-item">
              <span class="fortune-label" data-i18n="oracle.fortune">财运</span>
              <div class="fortune-stars" id="fortuneStars">★★★★☆</div>
            </div>
            <div class="fortune-item">
              <span class="fortune-label" data-i18n="oracle.luckyHourLabel">吉时</span>
              <span class="fortune-value" id="luckyHour">巳时 (9:00-11:00)</span>
            </div>
            <div class="fortune-item">
              <span class="fortune-label" data-i18n="oracle.luckyColor">吉色</span>
              <span class="fortune-value fortune-color-gold" data-i18n="oracle.gold">金色</span>
            </div>
          </div>
          <button class="btn btn-gold oracle-btn" id="drawOracleBtn" data-i18n="oracle.draw">
            🎴 每日求签
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 赵公明祖庙法事服务 ===== -->
  <section class="section ritual-section" id="ritual">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Temple Rituals</span>
        <h2 class="section-title" data-i18n="ritual.title">🏛️ 赵公明祖庙法事服务</h2>
        <p class="section-desc" data-i18n="ritual.desc">源自赵公明祖庙千年传承，链上法事诚心祈愿，财运亨通</p>
      </div>

      <!-- 祖庙介绍 -->
      <div class="ritual-intro">
        <div class="ritual-temple">
          <div class="temple-glow"></div>
          <div class="temple-icon">🏛️</div>
          <h3 class="temple-name">赵公明财神祖庙</h3>
          <p class="temple-location">📍 陕西省西安市周至县集贤镇赵大村</p>
          <p class="temple-desc">天下财神第一庙，正财神赵公明故里。千年香火不绝，灵验无比。现将祖庙法事与区块链技术融合，让您足不出户即可获得财神庇佑。</p>
          <div class="temple-stats">
            <div class="temple-stat">
              <span class="temple-stat-value">3,000+</span>
              <span class="temple-stat-label">年历史</span>
            </div>
            <div class="temple-stat">
              <span class="temple-stat-value">100万+</span>
              <span class="temple-stat-label">年朝拜人次</span>
            </div>
            <div class="temple-stat">
              <span class="temple-stat-value">99.8%</span>
              <span class="temple-stat-label">好评率</span>
            </div>
          </div>
        </div>
      </div>

      <!-- 法事项目 -->
      <div class="ritual-grid">
        <!-- 烧元宝 -->
        <div class="ritual-card burn-card">
          <div class="ritual-card-glow"></div>
          <div class="ritual-card-header">
            <div class="ritual-icon-wrap">
              <span class="ritual-icon">🪙</span>
              <div class="ritual-icon-ring"></div>
            </div>
            <div class="ritual-badge">🔥 热门法事</div>
          </div>
          <h3 class="ritual-title">烧元宝</h3>
          <p class="ritual-subtitle">焚化金银元宝 · 上达财神案前</p>
          <p class="ritual-desc">由祖庙法师在赵公明神像前举行焚化元宝仪式，将您的诚心通过金银元宝传达至财神案前，祈求财运亨通、生意兴隆。</p>
          
          <div class="ritual-features">
            <div class="ritual-feature">
              <span class="feature-icon">📜</span>
              <span>填写疏文，注明姓名与心愿</span>
            </div>
            <div class="ritual-feature">
              <span class="feature-icon">🔥</span>
              <span>祖庙法师现场焚化金银元宝</span>
            </div>
            <div class="ritual-feature">
              <span class="feature-icon">📸</span>
              <span>全程视频记录，链上存证</span>
            </div>
            <div class="ritual-feature">
              <span class="feature-icon">🎁</span>
              <span>赠送"财神赐福" NFT 凭证</span>
            </div>
          </div>

          <div class="ritual-packages">
            <div class="ritual-pkg" data-tier="basic">
              <span class="pkg-name">祈福包</span>
              <span class="pkg-detail">金元宝 x108</span>
              <span class="pkg-price">88 USDT</span>
            </div>
            <div class="ritual-pkg selected" data-tier="standard">
              <div class="pkg-popular">最受欢迎</div>
              <span class="pkg-name">旺财包</span>
              <span class="pkg-detail">金银元宝 x365</span>
              <span class="pkg-price">288 USDT</span>
            </div>
            <div class="ritual-pkg" data-tier="premium">
              <span class="pkg-name">鸿运包</span>
              <span class="pkg-detail">金银元宝 x888 + 大疏文</span>
              <span class="pkg-price">888 USDT</span>
            </div>
          </div>

          <button class="btn btn-primary btn-full ritual-btn" onclick="alert('请先连接钱包')">
            🔥 立即烧元宝
          </button>
          <p class="ritual-note">已有 <strong>12,888</strong> 位信众参与 · 每日法事直播 09:00 / 15:00</p>
        </div>

        <!-- 补财库 -->
        <div class="ritual-card treasury-card">
          <div class="ritual-card-glow"></div>
          <div class="ritual-card-header">
            <div class="ritual-icon-wrap">
              <span class="ritual-icon">🏦</span>
              <div class="ritual-icon-ring"></div>
            </div>
            <div class="ritual-badge treasury-badge">⭐ 镇庙之宝</div>
          </div>
          <h3 class="ritual-title">补财库</h3>
          <p class="ritual-subtitle">填补天库亏空 · 广开财源之路</p>
          <p class="ritual-desc">每人天生自带一座天财库，因前世今生消耗而亏空。由祖庙住持亲自主持补财库法事，填补天库亏空，让财运重新充盈。</p>
          
          <div class="ritual-features">
            <div class="ritual-feature">
              <span class="feature-icon">🧮</span>
              <span>测算天库亏空额度</span>
            </div>
            <div class="ritual-feature">
              <span class="feature-icon">📿</span>
              <span>住持领衔诵经祈福</span>
            </div>
            <div class="ritual-feature">
              <span class="feature-icon">🔥</span>
              <span>焚化补库专用疏文与元宝</span>
            </div>
            <div class="ritual-feature">
              <span class="feature-icon">🛡️</span>
              <span>赠送开光"聚财符" NFT</span>
            </div>
          </div>

          <div class="ritual-packages">
            <div class="ritual-pkg" data-tier="basic">
              <span class="pkg-name">小补财库</span>
              <span class="pkg-detail">基础补库法事</span>
              <span class="pkg-price">168 USDT</span>
            </div>
            <div class="ritual-pkg selected" data-tier="standard">
              <div class="pkg-popular">最受欢迎</div>
              <span class="pkg-name">中补财库</span>
              <span class="pkg-detail">标准补库 + 招财法事</span>
              <span class="pkg-price">588 USDT</span>
            </div>
            <div class="ritual-pkg" data-tier="premium">
              <span class="pkg-name">大补财库</span>
              <span class="pkg-detail">住持亲做 + 全套法事</span>
              <span class="pkg-price">1,888 USDT</span>
            </div>
          </div>

          <button class="btn btn-primary btn-full ritual-btn" onclick="alert('请先连接钱包')">
            🏦 立即补财库
          </button>
          <p class="ritual-note">已有 <strong>8,666</strong> 位信众参与 · 住持每月初一十五亲做</p>
        </div>
      </div>

      <!-- 法事流程 -->
      <div class="ritual-process">
        <h3 class="process-title">📋 法事流程</h3>
        <div class="process-steps">
          <div class="process-step">
            <div class="step-number">1</div>
            <div class="step-icon">⛓️</div>
            <h4>连接钱包</h4>
            <p>连接您的 Web3 钱包<br/>选择法事项目与套餐</p>
          </div>
          <div class="process-arrow">→</div>
          <div class="process-step">
            <div class="step-number">2</div>
            <div class="step-icon">📝</div>
            <h4>填写疏文</h4>
            <p>填写姓名、生辰及祈愿<br/>生成链上疏文</p>
          </div>
          <div class="process-arrow">→</div>
          <div class="process-step">
            <div class="step-number">3</div>
            <div class="step-icon">🔥</div>
            <h4>祖庙做法</h4>
            <p>法师于赵公明神像前<br/>举行法事，全程直播</p>
          </div>
          <div class="process-arrow">→</div>
          <div class="process-step">
            <div class="step-number">4</div>
            <div class="step-icon">🎁</div>
            <h4>链上存证</h4>
            <p>法事视频上链存证<br/>获赠专属祈福 NFT</p>
          </div>
        </div>
      </div>

      <!-- 信众见证 -->
      <div class="ritual-testimonials">
        <h3 class="process-title">🙏 信众见证</h3>
        <div class="testimonial-grid">
          <div class="testimonial-card">
            <div class="testimonial-header">
              <span class="testimonial-avatar">🧑‍💼</span>
              <div>
                <span class="testimonial-name">0x8a3f...d21e</span>
                <span class="testimonial-service">烧元宝 · 旺财包</span>
              </div>
            </div>
            <p class="testimonial-text">"做完法事第三天就收到了一笔大订单，财神爷真的很灵验！已经是第三次参与了。"</p>
            <div class="testimonial-stars">⭐⭐⭐⭐⭐</div>
          </div>
          <div class="testimonial-card">
            <div class="testimonial-header">
              <span class="testimonial-avatar">👩‍💻</span>
              <div>
                <span class="testimonial-name">0x2b7c...f9a3</span>
                <span class="testimonial-service">补财库 · 中补财库</span>
              </div>
            </div>
            <p class="testimonial-text">"补完财库之后运气明显变好，投资也开始盈利。链上存证很透明，值得信赖。"</p>
            <div class="testimonial-stars">⭐⭐⭐⭐⭐</div>
          </div>
          <div class="testimonial-card">
            <div class="testimonial-header">
              <span class="testimonial-avatar">👨‍🏫</span>
              <div>
                <span class="testimonial-name">0xf1e5...b84c</span>
                <span class="testimonial-service">烧元宝 · 鸿运包</span>
              </div>
            </div>
            <p class="testimonial-text">"视频直播看到法师在祖庙做法事非常震撼，NFT 凭证也很有纪念意义，强烈推荐！"</p>
            <div class="testimonial-stars">⭐⭐⭐⭐⭐</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 个人八字命理服务 ===== -->
  <section class="section bazi-section" id="bazi">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">BaZi Destiny</span>
        <h2 class="section-title" data-i18n="bazi.title">🔮 个人八字命理</h2>
        <p class="section-desc" data-i18n="bazi.desc">以赵公明财神法门解读您的八字命盘，精准剖析先天财运格局</p>
      </div>

      <!-- 八字输入区 -->
      <div class="bazi-hero-card">
        <div class="bazi-hero-glow"></div>
        <div class="bazi-hero-left">
          <h3 class="bazi-hero-title">输入您的出生信息</h3>
          <p class="bazi-hero-desc">八字由年柱、月柱、日柱、时柱组成，蕴含您一生的财运密码。财神殿结合千年命理学与 AI 智能分析，为您精准解读。</p>
          <form class="bazi-form" id="baziForm" onsubmit="return false;">
            <div class="bazi-form-row">
              <div class="bazi-field">
                <label>出生日期</label>
                <input type="date" id="baziDate" class="bazi-input" value="1990-01-01" />
              </div>
              <div class="bazi-field">
                <label>出生时辰</label>
                <select id="baziHour" class="bazi-input">
                  <option value="0">子时 (23:00-01:00)</option>
                  <option value="1">丑时 (01:00-03:00)</option>
                  <option value="2">寅时 (03:00-05:00)</option>
                  <option value="3">卯时 (05:00-07:00)</option>
                  <option value="4">辰时 (07:00-09:00)</option>
                  <option value="5">巳时 (09:00-11:00)</option>
                  <option value="6" selected>午时 (11:00-13:00)</option>
                  <option value="7">未时 (13:00-15:00)</option>
                  <option value="8">申时 (15:00-17:00)</option>
                  <option value="9">酉时 (17:00-19:00)</option>
                  <option value="10">戌时 (19:00-21:00)</option>
                  <option value="11">亥时 (21:00-23:00)</option>
                </select>
              </div>
              <div class="bazi-field">
                <label>性别</label>
                <select id="baziGender" class="bazi-input">
                  <option value="male">男 (乾造)</option>
                  <option value="female">女 (坤造)</option>
                </select>
              </div>
            </div>
            <button type="button" class="btn btn-primary btn-lg bazi-submit-btn" id="baziSubmitBtn">
              🔮 排盘解命
            </button>
          </form>
        </div>
        <div class="bazi-hero-right">
          <!-- 八字四柱展示 -->
          <div class="bazi-pillars" id="baziPillars">
            <div class="bazi-pillar">
              <span class="pillar-label">年柱</span>
              <span class="pillar-stem" id="pillarYearStem">丙</span>
              <span class="pillar-branch" id="pillarYearBranch">寅</span>
              <span class="pillar-element fire">🔥 火</span>
            </div>
            <div class="bazi-pillar">
              <span class="pillar-label">月柱</span>
              <span class="pillar-stem" id="pillarMonthStem">己</span>
              <span class="pillar-branch" id="pillarMonthBranch">丑</span>
              <span class="pillar-element earth">🌍 土</span>
            </div>
            <div class="bazi-pillar">
              <span class="pillar-label">日柱</span>
              <span class="pillar-stem" id="pillarDayStem">壬</span>
              <span class="pillar-branch" id="pillarDayBranch">午</span>
              <span class="pillar-element water">💧 水</span>
            </div>
            <div class="bazi-pillar">
              <span class="pillar-label">时柱</span>
              <span class="pillar-stem" id="pillarHourStem">丙</span>
              <span class="pillar-branch" id="pillarHourBranch">午</span>
              <span class="pillar-element fire">🔥 火</span>
            </div>
          </div>
        </div>
      </div>

      <!-- 八字分析结果 -->
      <div class="bazi-result" id="baziResult">
        <div class="bazi-result-grid">
          <!-- 财运总评 -->
          <div class="bazi-card bazi-fortune-card">
